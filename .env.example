# Supabase Configuration
# Get these from: https://app.supabase.com/project/_/settings/api

# Public URL - Safe to expose in frontend
VITE_SUPABASE_URL=your_supabase_url

# Anonymous Key - Safe to expose in frontend (has RLS protection)
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# Razorpay Payment Gateway Configuration
# Get these from: https://dashboard.razorpay.com/app/keys
VITE_RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxxxxx

# ⚠️ SECURITY WARNING ⚠️
# NEVER add RAZORPAY_KEY_SECRET here!
# The secret key should ONLY be used in your backend/server for signature verification
# This .env file is for frontend only - all values are exposed to browser

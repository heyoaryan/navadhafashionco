# Supabase Configuration
# Get these from: https://app.supabase.com/project/_/settings/api

# Public URL - Safe to expose in frontend
VITE_SUPABASE_URL=your_supabase_url

# Anonymous Key - Safe to expose in frontend (has RLS protection)
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# Cashfree Payment Gateway Configuration
# Get these from: https://merchant.cashfree.com/merchants/pg/developers/api-keys
VITE_CASHFREE_APP_ID=TEST11001660d542604c8bfb958f6d4d06610011
VITE_CASHFREE_MODE=sandbox

# ⚠️ SECURITY WARNING ⚠️
# NEVER add SUPABASE_SERVICE_ROLE_KEY or CASHFREE_SECRET_KEY here!
# These keys bypass security and should ONLY be used in backend/server
# This .env file is for frontend only - all values are exposed to browser
